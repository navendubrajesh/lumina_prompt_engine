# Lumina Prompt Engine - API Keys
# Copy this file to .env and fill in your keys. Never commit .env to git.

# OpenAI (for GPT-4o, Instructor, and DeepEval GEval judge)
OPENAI_API_KEY=sk-...

# Anthropic (for Claude 3.5 Sonnet - generators + Judge)
ANTHROPIC_API_KEY=sk-ant-...

# Google (for Gemini 1.5 Pro)
GOOGLE_API_KEY=...
# Or: GEMINI_API_KEY=...

# Mistral AI
MISTRAL_API_KEY=...

# Together AI or Replicate (for Llama 3.1 70B)
# LiteLLM routes meta-llama/llama-3.1-70b-instruct to Together by default
TOGETHER_API_KEY=...
# Or: REPLICATE_API_TOKEN=...

# Groq (for Groq Llama 3.3 70B). Required for MONEYSAVER mode; also used for Claude/Mistral/Llama/Groq slots in MONEYSAVER.
GROQ_API_KEY=...

# MONEYSAVER: same 6 cards, all powered by Groq. OpenAI slot uses GROQ_OPENAI_SIMULATE, Gemini uses GROQ_GEMINI_SIMULATE; judge may use these if set.
GROQ_OPENAI_SIMULATE=...
GROQ_GEMINI_SIMULATE=...
