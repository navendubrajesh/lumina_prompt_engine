<?xml version="1.0" encoding="UTF-8"?>
<!--
  Engine definitions for Lumina Prompt Engine.
  - engines: real LLM backends (model_id + display_name).
  - engines_moneysaver: same UI cards, all use Groq; display_name + api_key_env.
-->
<engine_config>
  <engines>
    <engine model_id="openai/gpt-4o" display_name="OpenAI GPT-4o" />
    <engine model_id="anthropic/claude-3-5-sonnet-20241022" display_name="Anthropic Claude 3.5 Sonnet" />
    <engine model_id="google/gemini-1.5-pro" display_name="Google Gemini 1.5 Pro" />
    <engine model_id="mistral/mistral-small-latest" display_name="Mistral AI" />
    <engine model_id="meta-llama/llama-3.1-70b-instruct" display_name="Meta Llama 3.1 70B" />
    <engine model_id="groq/llama-3.3-70b-versatile" display_name="Groq Llama 3.3 70B" />
  </engines>
  <!-- MONEYSAVER: only GROQ_API_KEY needed; all 6 cards use Groq -->
  <engines_moneysaver>
    <engine display_name="OpenAI GPT-4o" api_key_env="GROQ_API_KEY" />
    <engine display_name="Anthropic Claude 3.5 Sonnet" api_key_env="GROQ_API_KEY" />
    <engine display_name="Google Gemini 1.5 Pro" api_key_env="GROQ_API_KEY" />
    <engine display_name="Mistral AI" api_key_env="GROQ_API_KEY" />
    <engine display_name="Meta Llama 3.1 70B" api_key_env="GROQ_API_KEY" />
    <engine display_name="Groq Llama 3.3 70B" api_key_env="GROQ_API_KEY" />
  </engines_moneysaver>
</engine_config>
